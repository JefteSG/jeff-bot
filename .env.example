APP_ENV=development
SQLITE_PATH=db/jeff_bot.db

# Token da SUA conta do Discord (userbot via selfcord) — obrigatório
DISCORD_USER_TOKEN=

# Token do bot oficial do Discord (discord.py) — necessário para auto-resposta
DISCORD_BOT_TOKEN=

DISCORD_COMMAND_PREFIX=!

# DeepSeek — obrigatório para classificação de intenção e geração de respostas
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=90

# Personalidade do bot
# Opções: jeff_direct | friendly_mentor | strict_sre
BOT_PERSONALITY=jeff_direct
# Opcional: instruções extras para ajustar o tom sem alterar o preset
BOT_PERSONALITY_CUSTOM=

# Notion — necessário para criar cards de tarefa
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Comportamento do roteador
SENDER_DEFAULT_THRESHOLD=0.7

# Watchdog: tempo sem resposta antes de marcar para revisão (minutos)
AUTO_REPLY_DELAY_MINUTES=5
# Intervalo de verificação do watchdog (segundos)
WATCHDOG_POLL_SECONDS=30
# Habilita envio automático de resposta pelo bot oficial enquanto Jeff está ocupado
AUTO_REPLY_ENABLED=false

# SDK openai-agents — migração do bot oficial
# Habilita o padrão Agent + Runner + SQLiteSession no lugar de generate_reply()
USE_AGENTS_SDK=false
# Desativa envio de traces para a API da OpenAI (recomendado ao usar DeepSeek)
# Coloque false para ver traces locais via stdout
AGENTS_TRACING_DISABLED=true
